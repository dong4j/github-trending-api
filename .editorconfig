# ===========================================
# EditorConfig 统一跨编辑器配置
# https://editorconfig.org
# ===========================================

root = true

[*]
# 使用 UTF-8
charset = utf-8
# 行尾使用 LF
end_of_line = lf
# 文件末尾保留一个空行
insert_final_newline = true
# 去除行尾空白
trim_trailing_whitespace = true
# 缩进使用空格
indent_style = space

[*.go]
# Go 使用 tab 缩进 (gofmt 默认)
indent_style = tab
indent_size = 4

[*.{md,yml,yaml,json}]
# 文档与配置文件使用 2 空格缩进
indent_size = 2

[*.{mod,sum}]
# go.mod / go.sum 使用 tab
indent_style = tab

[Makefile]
# Makefile 必须使用 tab
indent_style = tab

[Dockerfile]
indent_size = 4
